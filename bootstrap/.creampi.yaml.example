models:
  worker: "anthropic/claude-sonnet-4"
  reviewer: "anthropic/claude-opus-4"

workflow:
  review: true
  maxReviewRounds: 2

vps:
  provider: hetzner      # only option today, extensible later
  region: nbg1            # Hetzner location (default: nbg1)
  size: cx22              # Hetzner server type (default: cx22)
